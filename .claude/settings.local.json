{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(cmake -B build)",
      "Bash(cmake --build build -j8)",
      "Bash(cmake --build build -j8 --target gpu_sim_tests)",
      "Bash(cmake -B /workspace/build)",
      "Bash(cmake --build /workspace/build -j8)",
      "Bash(./sim/tests/test_coalescing)",
      "Bash(./sim/tests/test_load_gather_buffer)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/log_tool_timing.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/log_tool_timing.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/log_tool_timing.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/log_tool_timing.py\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/log_tool_timing.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/log_tool_timing.py\""
          }
        ]
      }
    ]
  }
}
